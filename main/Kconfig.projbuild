menu "itoy OTA 配置"

config OTA_URL
    string "默认 OTA 升级服务器地址"
    default "https://api.tenclass.net/xiaozhi/ota/"
    help
        设备通过此 URL 检查固件更新和获取服务器配置。
        需要完整的 HTTP/HTTPS 地址，以 / 结尾。

# 开发板类型固定为 itoy（不可更改）
config BOARD_TYPE_ITOY_WIFI_LCD
    bool
    default y

# WiFi 配网方式 (build-time 选择)
choice ITOY_PROVISIONING_METHOD
    prompt "WiFi 配网方式"
    default ITOY_PROVISIONING_AP
    help
        选择首次配网方式。设备已存有 WiFi 凭据时直接连接，不进入配网。
        仅编译被选中的方式。

    config ITOY_PROVISIONING_AP
        bool "SoftAP + 网页配网 (默认)"
        help
            设备开启热点 Itoy-XXXX，手机连该热点后访问网页输入 WiFi 密码。

    config ITOY_PROVISIONING_BLE
        bool "蓝牙 BLE 配网 (ESP BLE Provisioning App)"
        select BT_ENABLED
        help
            用蓝牙配网。手机用 Espressif "ESP BLE Provisioning" App 扫描
            Itoy-XXXX，输入 PoP 并选择 WiFi 输入密码。
            会开启蓝牙栈 (Bluedroid, 约 +200~400KB flash)。
            注: BT 主机用 ESP-IDF 默认 (S3 = Bluedroid, 兼容 protocomm BLE)。
endchoice

# itoy-mogu RGB 灯带配置
config ITOY_RGB_LED_COUNT
    int "WS2812B RGB 灯珠数量"
    default 1
    help
        连接在 GPIO38 (U13 连接器 DIN) 的 WS2812B 灯带灯珠数量。
        根据实际灯带长度在 menuconfig 中修改。

endmenu
